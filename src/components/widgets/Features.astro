---
import { Icon } from 'astro-icon';

const items = [
	[
		{
			title: 'WordPress',
			description:
				'Se trata del CMS más popular del mercado,wordPress es un sistema de gestión de contenidos (CMS), un software utilizado para construir, modificar y mantener sitios web.',
			icon: 'tabler:brand-tailwind',
		},
		{
			title: 'React',
			description:
				'React es una biblioteca Javascript de código abierto diseñada para crear interfaces de usuario con el objetivo de facilitar el desarrollo de aplicaciones en una sola página',
			icon: 'tabler:components',
		},
		{
			title: 'Actualizado',
			description:
				'React, Vue.js, Server Cloud. Toda la vanguardia de la tecnologia en uso para usted',
			icon: 'tabler:list-check',
		},
	],
	[
		{
			title: 'Astro',
			description:
				'Astro es un marco web todo en uno para crear sitios web rápidos y centrados en el contenido .',
			icon: 'tabler:rocket',
		},
		{
			title: 'Optimización de motores de búsqueda (SEO)',
			description:
				'El posicionamiento en buscadores, optimización en motores de búsqueda o SEO es un conjunto de acciones orientadas a mejorar el posicionamiento de un sitio web en la lista de resultados de Google, Bing, u otros buscadores de internet',
			icon: 'tabler:arrows-right-left',
		},
		{
			title: 'Cloud Server',
			description:
				'Un servidor de nube es un recurso de servidor centralizado y agrupado que se aloja y distribuye a través de una red (generalmente Internet) y al que pueden acceder múltiples usuarios cuando lo necesiten.',
			icon: 'tabler:bulb',
		},
	],
];
---

<section class="scroll-mt-16" id="features">
	<div class="px-4 py-16 mx-auto max-w-6xl lg:px-8 lg:py-20">
		<div class="mb-10 md:mx-auto sm:text-center md:mb-12 max-w-3xl">
			<p class="text-base text-primary-600 dark:text-primary-200 font-semibold tracking-wide uppercase">Rasgos y Caracteristicas</p>
			<h2 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading">
				Como lo puedo ayudar como <span class="whitespace-nowrap">Programador?</span>
			</h2>
			<p class="max-w-3xl mx-auto sm:text-center text-xl text-gray-600 dark:text-slate-400">
				Mis Caracteristicas son de un fullstack, enfocado en el frontend
			</p>
		</div>
		<div class="grid mx-auto space-y-6 md:grid-cols-2 md:space-y-0">
			{
				items.map((subitems) => (
					<div class="space-y-8 sm:px-8">
						{subitems.map(({ title, description, icon }) => (
							<div class="flex flex-row max-w-md">
								<div class="mb-4 mr-4">
									<div class="flex items-center justify-center w-12 h-12 rounded-full bg-primary-500 dark:bg-primary-700">
										{icon && <Icon name={icon} class="w-6 h-6 text-white icon-light" />}
									</div>
								</div>
								<div>
									<h3 class="mb-3 text-xl font-bold">{title}</h3>
									<p class="text-gray-600 dark:text-slate-400">{description}</p>
								</div>
							</div>
						))}
					</div>
				))
			}
		</div>
	</div>
</section>
